# forge-backup configuration. Copy to /etc/forge-backup/config and edit.
# This file is sourced by forge-backup as bash. Keep it valid bash.

# rclone remote name (must match the remote in rclone.conf).
REMOTE="spaces"

# DigitalOcean Spaces bucket name.
BUCKET="your-bucket"

# UNIQUE per server. Used to namespace objects in the bucket. e.g. server-1.
SERVER_NAME="server-1"

# Root scanned for sites. Forge isolated users each get a home under here.
SITES_ROOT="/home"

# Log file path.
LOG="/home/forge/forge-backup.log"

# WordPress media dir, relative to a site root.
WP_UPLOADS="wp-content/uploads"

# Joomla media dirs, relative to a site root. Missing ones are skipped.
JOOMLA_DIRS=("images" "media" "attachments")
